      "item": [
        {
          "name": "Desktop visit - Moscow",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Visit accepted\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.accepted).to.eql(true);",
                  "    pm.expect(json.data.id).to.be.a(\"number\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visitor_id\": \"postman-desktop-moscow-{{$guid}}\",\n  \"site_host\": \"demo-site.local\",\n  \"page_title\": \"Главная страница\",\n  \"page_url\": \"https://demo-site.local/?utm_source=postman#hero\",\n  \"referrer\": \"https://search.example/results?q=amopoint\",\n  \"city\": \"Moscow\",\n  \"country\": \"RU\",\n  \"device_type\": \"desktop\",\n  \"browser\": \"Chrome\",\n  \"platform\": \"MacIntel\",\n  \"screen_width\": 1440,\n  \"screen_height\": 900,\n  \"language\": \"ru-RU\",\n  \"timezone\": \"Europe/Moscow\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/visits",
